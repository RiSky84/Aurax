# Frontend Environment Variables Example
# Copy this file to .env.local and update values as needed

# React App Configuration
REACT_APP_NAME=Aura
REACT_APP_VERSION=1.0.0

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Default Language
REACT_APP_DEFAULT_LANGUAGE=en

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_MOOD_TRACKING=true
REACT_APP_ENABLE_CRISIS_DETECTION=true

# UI Configuration
REACT_APP_MAX_CHAT_HISTORY=50
REACT_APP_MOOD_HISTORY_DAYS=30

# Logging
REACT_APP_LOG_LEVEL=info
REACT_APP_DEBUG_MODE=false

# Production Build
GENERATE_SOURCEMAP=false
