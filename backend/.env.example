# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here

# Database Configuration
# Choose one:
# Option 1: In-Memory Storage (default for demo)
# USE_SUPABASE=false

# Option 2: Supabase PostgreSQL (production)
USE_SUPABASE=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here  # Optional, for admin operations

# Legacy MongoDB (if needed)
# MONGODB_URI=mongodb://localhost:27017/mental-health-companion
